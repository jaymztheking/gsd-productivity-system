# Copy this file to k8s/secrets.yaml, fill in real values, then apply:
#   kubectl apply -f k8s/secrets.yaml
#
# secrets.yaml is gitignored — never commit it.
#
# stringData values are plain text (kubectl encodes them for you).

apiVersion: v1
kind: Secret
metadata:
  name: gsd-secrets
  namespace: gsd
type: Opaque
stringData:
  POSTGRES_PASSWORD: "change-me"
  # Must match POSTGRES_PASSWORD above
  DATABASE_URL: "postgresql+asyncpg://gsd:change-me@postgres:5432/gsd"
  N8N_BASIC_AUTH_PASSWORD: "change-me"
