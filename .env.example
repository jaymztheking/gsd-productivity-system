# Postgres
POSTGRES_USER=gsd
POSTGRES_PASSWORD=<change-me>
POSTGRES_DB=gsd
POSTGRES_PORT=5433

# API — password here must match POSTGRES_PASSWORD above
DATABASE_URL=postgresql+asyncpg://gsd:<change-me>@postgres:5432/gsd
API_PORT=8000

# UI
UI_PORT=3000
VITE_API_BASE_URL=http://localhost:8000

# n8n
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=<change-me>
N8N_WEBHOOK_URL=http://n8n:5678

# Weekly Digest (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
DIGEST_RECIPIENT=
